{
  "name": "piclaw",
  "version": "0.0.1",
  "description": "A Minimal OpenClaw Implementation Based on Pi-Mono",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "piclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "start": "node dist/cli.js start",
    "dev": "tsx src/cli.ts start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ai",
    "agent",
    "pi-mono",
    "openclaw"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@wecom/aibot-node-sdk": "^1.0.1",
    "node-telegram-bot-api": "^0.64.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@types/node": "^20.10.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "commander": "^12.1.0",
    "eslint": "^10.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
